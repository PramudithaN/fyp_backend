# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# NewsAPI Configuration (primary)
# Get your key from: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# NewsData.io Configuration (backup option)
# Get your key from: https://newsdata.io/
NEWSDATA_KEY=your_newsdata_key_here

# Optional: Sentiment Analysis Mode
# Options: simple (keyword-based) or finbert (AI-based)
SENTIMENT_MODE=finbert

# FinBERT Model Loading
# Set to 'true' to skip preloading at startup (useful for deployments without HuggingFace access)
# Model will be loaded on first sentiment analysis request instead
SKIP_FINBERT_PRELOAD=false

# Web Scraper Configuration
# Enable/disable the daily automated scraper (default: true)
SCRAPER_ENABLED=true

# Hour (UTC) to run the daily scrape (default: 6)
SCRAPER_SCHEDULE_HOUR=6

# Minute to run the daily scrape (default: 0)
SCRAPER_SCHEDULE_MINUTE=0
